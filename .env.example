# Local Docker Compose settings
POSTGRES_DB=passgen
POSTGRES_USER=passgen
POSTGRES_PASSWORD=change-me

# 32-byte key in Base64. Generate with:
#   go run ./cmd/passgen keygen
PASSGEN_TRANSPORT_KEY_BASE64=REPLACE_WITH_32_BYTE_BASE64_KEY

# Optional tuning
PASSGEN_RATE_LIMIT_RPS=30
PASSGEN_RATE_LIMIT_BURST=60

# Optional integration tests DSN
PASSGEN_TEST_DSN=postgres://passgen:change-me@localhost:5432/passgen?sslmode=disable
