# PostgreSQL settings for local Docker Compose
POSTGRES_DB=passgen
POSTGRES_USER=passgen
POSTGRES_PASSWORD=change-me

# 32-byte key encoded as base64 (raw/std without padding is also accepted by app).
# Generate one with:
#   go run ./cmd/passgen keygen
PASSGEN_TRANSPORT_KEY_BASE64=REPLACE_WITH_32_BYTE_BASE64_KEY

# Integration tests DSN (used only when you want real DB tests locally)
PASSGEN_TEST_DSN=postgres://passgen:change-me@localhost:5432/passgen?sslmode=disable
